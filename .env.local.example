# ============================================================
# Plugio Admin — Environment Variables
# ============================================================
# Copy to .env.local and fill in values.
# NEVER commit .env.local to version control.
# ============================================================

# ── NextAuth (Auth.js v5) ──────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=YOUR_NEXTAUTH_SECRET_MIN_32_CHARS

# ── Google OAuth2 ─────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs must include:
#   http://localhost:3001/api/auth/callback/google  (dev)
#   https://admin.plugio.app/api/auth/callback/google  (prod)
AUTH_GOOGLE_ID=YOUR_GOOGLE_CLIENT_ID
AUTH_GOOGLE_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# ── Database (same MySQL as Plugio backend) ───────────────
# Use the same plugio_db that Spring Boot connects to.
# You can use the same credentials or a separate read-write user.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=plugio_db
DB_USERNAME=plugio_user
DB_PASSWORD=YOUR_DB_PASSWORD

# ── App URL (for NextAuth callbacks) ─────────────────────
# Development
NEXTAUTH_URL=http://localhost:3001
# Production (uncomment and set):
# NEXTAUTH_URL=https://admin.plugio.app

# ── App Version ──────────────────────────────────────────
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_ENVIRONMENT=development

# ── Backend Integration ──────────────────────────────────
# Spring Boot API URL
BACKEND_API_URL=http://localhost:8080
# Shared secret API key matching app.admin.api-key in backend properties
ADMIN_API_KEY=dev-secret-key-12345
